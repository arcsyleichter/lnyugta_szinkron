# Automatikusan generált titkok — SOHA ne kerüljön verziókezelésbe
data/.secrets.json
data/access-codes.json

# Futásidőben növekvő tevékenység-napló — nem "kiindulási" adat
data/activity-log.jsonl

# Készlet-nyilvántartás — a szerver automatikusan létrehozza első induláskor,
# nem kell előre a repóba tenni
data/stock.db

# Cikktörzs kétirányú szinkron függő módosításai — szintén automatikusan
# létrejön első induláskor
data/product-changes.db

# Licenc-adatbázis (funkció-katalógus + cégenkénti kiosztás) — szintén
# automatikusan létrejön első induláskor, élő/szerverenkénti adat
data/license.db

# Feltöltés közbeni ideiglenes fájlok
data/companies/*.db.uploading

# A CÉGEK ÉLŐ, VALÓDI ADATBÁZISAI — ez SOHA nem tartozott verziókezelésbe.
# EZ VOLT AZ ÖZÖKÉR-OK egy korábbi, komoly adatvesztésnek: mivel ez a sor
# korábban hiányzott, ezek a folyamatosan változó, éles fájlok véletlenül
# bekerülhettek a git-be, és egy git-művelet (stash/checkout/fresh clone)
# összezavarta/felülírta őket. A VPS-en lévő data/companies/ mappa a
# rendszer élő, elsődleges adata — kizárólag a szerveren, biztonsági
# mentésekkel kezelendő, git-en KERESZTÜL SOHA nem mozgatható.
data/companies/
data/uploads/
data/users.db

# OS / szerkesztő
.DS_Store
node_modules/
__pycache__/
*.pyc
